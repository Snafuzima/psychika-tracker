<script>
var today = new Date();
var dateStr = today.toLocaleDateString('ru-RU', {weekday:'long',year:'numeric',month:'long',day:'numeric'});
var dateKey = today.toISOString().split('T')[0];
document.getElementById('hdrDate').textContent = dateStr;

try {
