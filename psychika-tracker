  scheduleSave();
}
function getRadio(gid){
  var s = document.querySelector('#'+gid+' .radio-btn.sel');
  return s ? s.textContent.trim() : '—';
}

var waterMl = 0;
function updateWaterDisplay(){
  document.getElementById('waterNum').textContent = waterMl;
  var inp = document.getElementById('water');
  if (inp) inp.value = waterMl > 0 ? waterMl : '';
}
function adjustWater(d){ waterMl = Math.max(0, waterMl+d); updateWaterDisplay(); scheduleSave(); }
function addCup(n){ adjustWater(200*n); }
function syncWaterInput(){
  waterMl = parseInt(document.getElementById('water').value) || 0;
  document.getElementById('waterNum').textContent = waterMl;
  scheduleSave();
}

function getSleepTime(){
  var h = document.getElementById('sleepH').value;
  var m = document.getElementById('sleepM').value;
  if (!h && !m) return '—';
  return (h ? h+'ч. ' : '') + (m ? m+'мин.' : '');
}

function g(id){ var el=document.getElementById(id); return el?(el.value.trim()||'—'):'—'; }
function collect(){
  return {
    date:dateStr,
    water:waterMl||'—', coffeeML:g('coffeeML'),
    calories:g('calories'), protein:g('protein'), fats:g('fats'), carbs:g('carbs'),
    overeating:getRadio('overeating'), proteinGoal:getRadio('proteinGoal'),
    weight:g('weight'), wellbeing:document.getElementById('wellbeing').value,
    swelling:g('swelling'), digestive:getRadio('digestive'),
    bodyConclusion:g('bodyConclusion'), tomorrowFocus:g('tomorrowFocus'),
    bedtime:g('bedtime'), wakeTime:g('wakeTime'),
    sleepH:g('sleepH'), sleepM:g('sleepM'), sleepTime:getSleepTime(),
    wakeUps:g('wakeUps'), sleepQ:document.getElementById('sleepQ').value,
    steps:g('steps'), activityLevel:g('activityLevel'),
    workoutType:g('workoutType'), workoutDur:g('workoutDur'),
    stress:document.getElementById('stress').value,
    appetite:getRadio('appetite'), sweetCraving:getRadio('sweetCraving'),
    eveningE:document.getElementById('eveningE').value
  };
}

var saveTimer = null;
function scheduleSave(){ setSaveStatus('saving'); clearTimeout(saveTimer); saveTimer=setTimeout(doSave,1500); }
function doSave(){
  try{ localStorage.setItem('sandra_'+dateKey,JSON.stringify(collect())); setSaveStatus('saved'); }
  catch(e){ setSaveStatus(''); }
}
function manualSave(){ clearTimeout(saveTimer); doSave(); showToast('Сохранено'); }
function setSaveStatus(s){
  document.getElementById('saveStatus').className='save-status '+s;
  document.getElementById('saveText').textContent=s==='saving'?'сохранение...':s==='saved'?'сохранено':'не сохранено';
