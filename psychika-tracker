    var bmi=(w/((h/100)*(h/100))).toFixed(1);
    var cat=bmi<18.5?'дефицит':bmi<25?'норма':bmi<30?'избыток':'ожирение';
    el.textContent=bmi+' ('+cat+')';
  } else { el.textContent='— заполните рост и вес'; }
}
