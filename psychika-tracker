<!DOCTYPE html>

<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Sandra">
<title>Sandra</title>
<link id="appIcon" rel="apple-touch-icon">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<script>
(function(){
  var c=document.createElement('canvas'); c.width=c.height=512;
  var x=c.getContext('2d');
  var g=x.createLinearGradient(0,0,512,512);
  g.addColorStop(0,'#4a8c76'); g.addColorStop(1,'#2d6050');
  x.fillStyle=g;
  var r=90; x.beginPath();
  x.moveTo(r,0);x.lineTo(512-r,0);x.quadraticCurveTo(512,0,512,r);
  x.lineTo(512,512-r);x.quadraticCurveTo(512,512,512-r,512);
  x.lineTo(r,512);x.quadraticCurveTo(0,512,0,512-r);
  x.lineTo(0,r);x.quadraticCurveTo(0,0,r,0);
  x.closePath();x.fill();
  x.fillStyle='rgba(255,255,255,0.93)';
  x.textAlign='center';x.textBaseline='middle';
  x.font='500 96px Georgia,serif';
  x.fillText('Sandra',256,256);
  document.getElementById('appIcon').href=c.toDataURL('image/png');
})();
</script>
<style>
:root {
  --bg:#0c0e12; --s1:#111418; --s2:#171b22; --s3:#1e232d;
  --border:#262c38; --border2:#2e3545;
  --green:#5a9e82; --green2:#3d7a65;
  --gold:#c4a46b; --lav:#8b82c4;
  --text:#e8e2d8; --text2:#8a8e9a; --text3:#4a4e5a;
  --r:14px; --ease:0.22s cubic-bezier(0.4,0,0.2,1);
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
body{font-family:'DM Mono',monospace;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;}

/* HEADER */
.hdr{position:sticky;top:0;z-index:100;background:rgba(12,14,18,0.94);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-bottom:1px solid var(–border);padding:14px 20px 10px;display:flex;align-items:center;justify-content:space-between;}
.hdr-title{font-family:‘Cormorant Garamond’,serif;font-size:24px;font-weight:600;color:var(–green);}
.hdr-date{font-size:10px;color:var(–text3);margin-top:1px;letter-spacing:1.5px;text-transform:uppercase;}
.save-status{font-size:10px;color:var(–text3);display:flex;align-items:center;gap:5px;}
.save-status.saving{color:var(–gold);}
.save-status.saved{color:var(–green);}
.save-dot{width:6px;height:6px;border-radius:50%;background:var(–text3);transition:var(–ease);}
.save-status.saving .save-dot{background:var(–gold);animation:pulse 1s infinite;}
.save-status.saved .save-dot{background:var(–green);}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.3}}

/* TABS */
.tabs{display:flex;gap:3px;padding:10px 16px;overflow-x:auto;scrollbar-width:none;border-bottom:1px solid var(–border);background:var(–bg);position:sticky;top:62px;z-index:90;}
.tabs::-webkit-scrollbar{display:none;}
.tab{flex-shrink:0;padding:6px 13px;border-radius:20px;font-size:11px;font-family:‘DM Mono’,monospace;border:1px solid var(–border);background:transparent;color:var(–text2);cursor:pointer;transition:var(–ease);white-space:nowrap;}
.tab.active{background:var(–green);border-color:var(–green);color:var(–bg);font-weight:500;}

/* CONTENT */
.content{padding:18px 18px 140px;max-width:600px;margin:0 auto;}
.section{display:none;animation:up 0.28s ease;}
.section.active{display:block;}
@keyframes up{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}

/* CARDS */
.card{background:var(–s1);border:1px solid var(–border);border-radius:var(–r);padding:16px;margin-bottom:12px;}
.card-hdr{display:flex;align-items:center;gap:9px;margin-bottom:14px;}
.card-ico{font-size:17px;}
.card-title{font-family:‘Cormorant Garamond’,serif;font-size:16px;font-weight:600;color:var(–text);}
.card-sub{font-size:10px;color:var(–text3);margin-top:1px;text-transform:uppercase;}

/* FIELDS */
.field{margin-bottom:12px;}
.field:last-child{margin-bottom:0;}
label{display:block;font-size:10px;color:var(–text2);margin-bottom:5px;letter-spacing:0.8px;text-transform:uppercase;}
input[type=text],input[type=number],input[type=time],textarea,select{width:100%;background:var(–s2);border:1px solid var(–border);border-radius:8px;color:var(–text);font-family:‘DM Mono’,monospace;font-size:14px;padding:9px 12px;outline:none;transition:var(–ease);-webkit-appearance:none;}
input:focus,textarea:focus,select:focus{border-color:var(–green);background:var(–s3);}
textarea{resize:none;min-height:72px;line-height:1.55;}
select option{background:var(–s2);}

/* SLIDER */
.slider-wrap{display:flex;align-items:center;gap:12px;}
.slider-val{font-size:20px;font-weight:500;color:var(–green);min-width:26px;text-align:center;font-family:‘Cormorant Garamond’,serif;}
input[type=range]{flex:1;-webkit-appearance:none;appearance:none;height:3px;border-radius:3px;background:var(–border);outline:none;padding:0;border:none;}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:20px;height:20px;border-radius:50%;background:var(–green);cursor:pointer;border:3px solid var(–bg);box-shadow:0 0 0 1px var(–green);}

/* RADIO */
.radio-group{display:flex;flex-wrap:wrap;gap:7px;}
.radio-btn{padding:5px 12px;border-radius:20px;border:1px solid var(–border);background:transparent;color:var(–text2);font-family:‘DM Mono’,monospace;font-size:12px;cursor:pointer;transition:var(–ease);}
.radio-btn.sel{background:var(–gold);border-color:var(–gold);color:var(–bg);}

/* TWO COL */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:12px;}

/* SLEEP */
.sleep-wrap{display:flex;align-items:center;gap:8px;}
.sleep-wrap select{flex:1;}
.sleep-sep{color:var(–green);font-size:16px;font-weight:500;}

/* WATER */
.water-counter{display:flex;align-items:center;background:var(–s2);border:1px solid var(–border);border-radius:10px;overflow:hidden;margin-bottom:8px;}
.water-display{flex:1;text-align:center;padding:10px 0;}
.water-num{font-size:22px;font-weight:500;color:var(–green);font-family:‘Cormorant Garamond’,serif;display:block;}
.water-unit{font-size:11px;color:var(–text3);}
.water-btn{padding:14px 18px;background:transparent;border:none;color:var(–text2);font-size:18px;cursor:pointer;transition:var(–ease);}
.water-btn:first-child{border-right:1px solid var(–border);}
.water-btn:last-child{border-left:1px solid var(–border);}
.water-btn:active{background:var(–s3);color:var(–green);}
.cups-row{display:flex;gap:8px;margin-bottom:8px;}
.cup-btn{flex:1;padding:9px;background:var(–s3);border:1px solid var(–border2);border-radius:8px;color:var(–text2);font-family:‘DM Mono’,monospace;font-size:11px;cursor:pointer;transition:var(–ease);text-align:center;}
.cup-btn:active{background:var(–green2);color:var(–text);}

/* BOTTOM BAR */
.bar{position:fixed;bottom:0;left:0;right:0;padding:10px 16px;padding-bottom:max(10px,env(safe-area-inset-bottom));background:rgba(12,14,18,0.96);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-top:1px solid var(–border);z-index:200;}
.bar-row{display:flex;gap:9px;}
.bar-info-row{display:none;flex-direction:row;gap:9px;margin-top:8px;animation:up 0.2s ease;}
.bar-info-row.open{display:flex;}
.btn{flex:1;padding:12px 8px;border-radius:10px;font-family:‘DM Mono’,monospace;font-size:12px;font-weight:500;border:none;cursor:pointer;transition:var(–ease);}
.btn:active{transform:scale(0.97);opacity:0.85;}
.btn-primary{background:var(–green);color:var(–bg);}
.btn-secondary{background:var(–s2);color:var(–text);border:1px solid var(–border);}
.btn-info{background:var(–s2);color:var(–text);border:1px solid var(–lav);}
.btn-info.open{background:var(–lav);color:var(–bg);}
.info-item{flex:1;padding:10px 6px;border-radius:10px;background:var(–s2);border:1px solid var(–border);color:var(–text2);font-family:‘DM Mono’,monospace;font-size:11px;cursor:pointer;transition:var(–ease);text-align:center;}
.info-item:active{background:var(–s3);color:var(–text);}

/* MODALS */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.78);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);z-index:500;padding:20px;align-items:flex-end;}
.overlay.open{display:flex;}
.modal{background:var(–s1);border:1px solid var(–border);border-radius:20px;padding:22px;width:100%;max-width:600px;margin:0 auto;animation:up 0.28s ease;max-height:82vh;overflow-y:auto;}
.modal-title{font-family:‘Cormorant Garamond’,serif;font-size:20px;font-weight:600;color:var(–green);margin-bottom:3px;}
.modal-sub{font-size:10px;color:var(–text3);margin-bottom:16px;letter-spacing:1px;text-transform:uppercase;}
.modal-btns{display:flex;gap:9px;margin-top:14px;}
.export-box{background:var(–s2);border:1px solid var(–border);border-radius:10px;padding:14px;font-size:11px;color:var(–text2);white-space:pre-wrap;max-height:300px;overflow-y:auto;line-height:1.65;font-family:‘DM Mono’,monospace;}
.hist-empty{text-align:center;color:var(–text3);font-size:13px;padding:28px 0;}
.hist-item{background:var(–s2);border:1px solid var(–border);border-radius:10px;padding:13px;margin-bottom:9px;cursor:pointer;transition:var(–ease);}
.hist-item:active{opacity:0.7;}
.hist-date{font-size:13px;color:var(–green);font-weight:500;margin-bottom:6px;}
.hist-tags{font-size:11px;color:var(–text3);display:flex;gap:8px;flex-wrap:wrap;}
.hist-tag{background:var(–border);padding:2px 8px;border-radius:10px;}

/* ONBOARDING */
.onb{position:fixed;inset:0;z-index:1000;background:var(–bg);display:flex;flex-direction:column;overflow-y:auto;}
.onb.hidden{display:none;}
.onb-hdr{padding:52px 24px 24px;background:linear-gradient(180deg,#0c2a1e 0%,var(–bg) 100%);text-align:center;}
.onb-logo{font-family:‘Cormorant Garamond’,serif;font-size:42px;font-weight:300;color:var(–green);margin-bottom:6px;}
.onb-tag{font-size:11px;color:var(–text3);letter-spacing:2px;text-transform:uppercase;}
.onb-body{padding:8px 20px 140px;max-width:600px;margin:0 auto;width:100%;}
.onb-sec{font-family:‘Cormorant Garamond’,serif;font-size:18px;font-weight:600;color:var(–green);margin:22px 0 12px;}
.onb-card{background:var(–s1);border:1px solid var(–border);border-radius:var(–r);padding:16px;margin-bottom:10px;}
.onb-step{display:none;}
.onb-step.active{display:block;animation:up 0.3s ease;}
.onb-footer{position:fixed;bottom:0;left:0;right:0;padding:12px 20px;padding-bottom:max(12px,env(safe-area-inset-bottom));background:rgba(12,14,18,0.97);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-top:1px solid var(–border);}
.onb-progress{display:flex;gap:4px;justify-content:center;margin-bottom:10px;}
.onb-dot{width:6px;height:6px;border-radius:50%;background:var(–border);transition:var(–ease);}
.onb-dot.active{background:var(–green);width:18px;border-radius:3px;}
.bmi-display{padding:9px 12px;background:var(–s2);border:1px solid var(–border);border-radius:8px;font-size:14px;color:var(–green);}

/* TOAST */
.toast{position:fixed;top:72px;left:50%;transform:translateX(-50%) translateY(-16px);background:var(–green);color:var(–bg);padding:9px 18px;border-radius:20px;font-size:12px;font-weight:500;opacity:0;transition:all 0.28s ease;z-index:999;pointer-events:none;white-space:nowrap;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
::-webkit-scrollbar{width:3px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(–border);border-radius:3px;}
</style>

</head>
<body>

<div class="hdr">
  <div>
    <div class="hdr-title">🌿 Sandra</div>
    <div class="hdr-date" id="hdrDate"></div>
  </div>
  <div class="save-status" id="saveStatus">
    <div class="save-dot"></div>
    <span id="saveText">не сохранено</span>
  </div>
</div>

<div class="tabs">
  <button class="tab active" onclick="switchTab(0)">🍽 Питание и вода</button>
  <button class="tab" onclick="switchTab(1)">⚖️ Тело</button>
  <button class="tab" onclick="switchTab(2)">🛌 Сон</button>
  <button class="tab" onclick="switchTab(3)">🚶 Активность</button>
  <button class="tab" onclick="switchTab(4)">🧠 Психо-фон</button>
</div>

<div class="content">

  <!-- 0: ПИТАНИЕ И ВОДА -->

  <div class="section active" id="section-0">
    <div class="card">
      <div class="card-hdr"><span class="card-ico">💧</span><div><div class="card-title">Гидратация</div></div></div>
      <div class="field">
        <label>Вода</label>
        <div class="water-counter">
          <button class="water-btn" onclick="adjustWater(-200)">−</button>
          <div class="water-display">
            <span class="water-num" id="waterNum">0</span>
            <span class="water-unit">мл</span>
          </div>
          <button class="water-btn" onclick="adjustWater(200)">+</button>
        </div>
        <div class="cups-row">
          <button class="cup-btn" onclick="addCup(1)">🥤 +1 стакан (200 мл)</button>
          <button class="cup-btn" onclick="addCup(2)">🥤🥤 +2 стакана</button>
        </div>
        <input type="number" id="water" placeholder="или введите вручную (мл)" oninput="syncWaterInput()">
      </div>
      <div class="field">
        <label>Кофе / чай (мл)</label>
        <input type="number" id="coffeeML" placeholder="400">
      </div>
    </div>
    <div class="card">
      <div class="card-hdr"><span class="card-ico">🍽</span><div><div class="card-title">КБЖУ</div></div></div>
      <div class="two-col">
        <div class="field"><label>Калории</label><input type="number" id="calories" placeholder="2000"></div>
        <div class="field"><label>Белки (г)</label><input type="number" id="protein" placeholder="130"></div>
      </div>
      <div class="two-col">
        <div class="field"><label>Жиры (г)</label><input type="number" id="fats" placeholder="70"></div>
        <div class="field"><label>Углеводы (г)</label><input type="number" id="carbs" placeholder="200"></div>
      </div>
      <div class="field">
        <label>Переедание?</label>
        <div class="radio-group" id="overeating">
          <button class="radio-btn" onclick="radio('overeating',this)">нет</button>
          <button class="radio-btn" onclick="radio('overeating',this)">да</button>
        </div>
      </div>
      <div class="field">
        <label>Белок выполнен?</label>
        <div class="radio-group" id="proteinGoal">
          <button class="radio-btn" onclick="radio('proteinGoal',this)">да</button>
          <button class="radio-btn" onclick="radio('proteinGoal',this)">нет</button>
        </div>
      </div>
    </div>
  </div>

  <!-- 1: ТЕЛО -->

  <div class="section" id="section-1">
    <div class="card">
      <div class="card-hdr"><span class="card-ico">⚖️</span><div><div class="card-title">Тело</div><div class="card-sub">Утренние показатели</div></div></div>
      <div class="two-col">
        <div class="field"><label>Вес (кг)</label><input type="number" id="weight" placeholder="70.5" step="0.1"></div>
        <div class="field">
          <label>Самочувствие (1–5)</label>
          <div class="slider-wrap">
            <input type="range" min="1" max="5" value="3" id="wellbeing" oninput="sl('wellbeing','wellbeingV')">
            <div class="slider-val" id="wellbeingV">3</div>
          </div>
        </div>
      </div>
      <div class="field"><label>Отёчность / тяжесть</label><input type="text" id="swelling" placeholder="нет / ноги / живот..."></div>
      <div class="field">
        <label>ЖКТ</label>
        <div class="radio-group" id="digestive">
          <button class="radio-btn" onclick="radio('digestive',this)">норма</button>
          <button class="radio-btn" onclick="radio('digestive',this)">тяжесть</button>
          <button class="radio-btn" onclick="radio('digestive',this)">вздутие</button>
          <button class="radio-btn" onclick="radio('digestive',this)">проблемы</button>
        </div>
      </div>
    </div>
    <div class="card">
      <div class="card-hdr"><span class="card-ico">🎯</span><div><div class="card-title">Мини-вывод дня</div></div></div>
      <div class="field"><textarea id="bodyConclusion" placeholder="Что было главным? Что сработало? Где потеря контроля?"></textarea></div>
    </div>
    <div class="card">
      <div class="card-hdr"><span class="card-ico">🔄</span><div><div class="card-title">Фокус на завтра</div></div></div>
      <div class="field"><input type="text" id="tomorrowFocus" placeholder="Например: вода 2 л или сон до 23:00"></div>
    </div>
  </div>

  <!-- 2: СОН -->

  <div class="section" id="section-2">
    <div class="card">
      <div class="card-hdr"><span class="card-ico">🛌</span><div><div class="card-title">Сон</div></div></div>
      <div class="two-col">
        <div class="field"><label>Время отбоя</label><input type="time" id="bedtime" value="23:30"></div>
        <div class="field"><label>Время подъёма</label><input type="time" id="wakeTime" value="07:30"></div>
      </div>
      <div class="field">
        <label>Время сна (факт)</label>
        <div class="sleep-wrap">
          <select id="sleepH">
            <option value="">ч</option>
            <option>0</option><option>1</option><option>2</option><option>3</option><option>4</option>
            <option>5</option><option>6</option><option>7</option><option>8</option><option>9</option>
            <option>10</option><option>11</option><option>12</option>
          </select>
          <span class="sleep-sep">:</span>
          <select id="sleepM">
            <option value="">мин</option>
            <option value="0">00</option><option value="5">05</option><option value="10">10</option>
            <option value="15">15</option><option value="20">20</option><option value="25">25</option>
            <option value="30">30</option><option value="35">35</option><option value="40">40</option>
            <option value="45">45</option><option value="50">50</option><option value="55">55</option>
          </select>
        </div>
      </div>
      <div class="two-col">
        <div class="field"><label>Пробуждений</label><input type="number" id="wakeUps" placeholder="0" min="0"></div>
        <div class="field">
          <label>Качество (1–5)</label>
          <div class="slider-wrap">
            <input type="range" min="1" max="5" value="3" id="sleepQ" oninput="sl('sleepQ','sleepQV')">
            <div class="slider-val" id="sleepQV">3</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 3: АКТИВНОСТЬ -->

  <div class="section" id="section-3">
    <div class="card">
      <div class="card-hdr"><span class="card-ico">🚶</span><div><div class="card-title">Движение</div></div></div>
      <div class="two-col">
        <div class="field"><label>Шаги</label><input type="number" id="steps" placeholder="8000"></div>
        <div class="field">
          <label>Общая активность</label>
          <select id="activityLevel">
            <option value="">—</option><option>низкая</option><option>средняя</option><option>высокая</option>
          </select>
        </div>
      </div>
      <div class="two-col">
        <div class="field"><label>Тип тренировки</label><input type="text" id="workoutType" placeholder="бег, силовая..."></div>
        <div class="field"><label>Длительность (мин)</label><input type="number" id="workoutDur" placeholder="45"></div>
      </div>
    </div>
  </div>

  <!-- 4: ПСИХО-ФОН -->

  <div class="section" id="section-4">
    <div class="card">
      <div class="card-hdr"><span class="card-ico">🧠</span><div><div class="card-title">Психо-фон</div></div></div>
      <div class="field">
        <label>Стресс (1–5)</label>
        <div class="slider-wrap">
          <input type="range" min="1" max="5" value="3" id="stress" oninput="sl('stress','stressV')">
          <div class="slider-val" id="stressV">3</div>
        </div>
      </div>
      <div class="field">
        <label>Аппетит</label>
        <div class="radio-group" id="appetite">
          <button class="radio-btn" onclick="radio('appetite',this)">низкий</button>
          <button class="radio-btn" onclick="radio('appetite',this)">норм</button>
          <button class="radio-btn" onclick="radio('appetite',this)">высокий</button>
        </div>
      </div>
      <div class="field">
        <label>Тяга к сладкому</label>
        <div class="radio-group" id="sweetCraving">
          <button class="radio-btn" onclick="radio('sweetCraving',this)">нет</button>
          <button class="radio-btn" onclick="radio('sweetCraving',this)">умеренная</button>
          <button class="radio-btn" onclick="radio('sweetCraving',this)">сильная</button>
        </div>
      </div>
      <div class="field">
        <label>Энергия вечером (1–5)</label>
        <div class="slider-wrap">
          <input type="range" min="1" max="5" value="3" id="eveningE" oninput="sl('eveningE','eveningEV')">
          <div class="slider-val" id="eveningEV">3</div>
        </div>
      </div>
    </div>
