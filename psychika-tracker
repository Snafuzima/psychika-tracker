function openHistory(){
  var list=document.getElementById('histList');
  list.innerHTML='';
  var keys=[];
  try{
    for(var i=0;i<localStorage.length;i++){
      var k=localStorage.key(i);
      if(k&&k.startsWith('sandra_')&&k!=='sandra_profile') keys.push(k);
    }
  }catch(e){}
  keys.sort().reverse();
  if(!keys.length){
    list.innerHTML='<div class="hist-empty">Пока нет сохранённых записей</div>';
  } else {
    keys.forEach(function(k){
      try{
        var d=JSON.parse(localStorage.getItem(k));
